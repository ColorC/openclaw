{
  "name": "@openclaw/toyshop",
  "version": "2026.2.20-1",
  "description": "ToyShop - Low-supervision software factory with OpenSpec contracts and OpenHands integration",
  "keywords": [
    "ai-agent",
    "development-pipeline",
    "openhands",
    "openspec",
    "software-factory",
    "toyshop"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist/",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "openclaw": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
